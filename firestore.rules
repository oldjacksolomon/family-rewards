rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Is the current user a parent of this family?
    function isParent(familyId) {
      let fam = get(/databases/$(database)/documents/families/$(familyId)).data;
      return request.auth != null && (
        request.auth.uid == familyId ||
        (fam.parentUids != null && request.auth.uid in fam.parentUids)
      );
    }

    match /families/{familyId} {
      allow read: if true;
      // Only the creator can create (their UID = doc ID)
      allow create: if request.auth != null && request.auth.uid == familyId;
      allow update: if request.auth != null && (
        // Creator can always update
        request.auth.uid == familyId ||
        // Any existing parent can update
        (resource.data.parentUids != null && request.auth.uid in resource.data.parentUids) ||
        // Invite acceptance: add exactly yourself to parentUids, no other changes
        (resource.data.parentUids != null &&
         request.resource.data.parentUids.hasAll(resource.data.parentUids) &&
         request.resource.data.parentUids.size() == resource.data.parentUids.size() + 1 &&
         request.auth.uid in request.resource.data.parentUids &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentUids']))
      );
      allow delete: if request.auth != null && request.auth.uid == familyId;

      match /children/{childId} {
        allow read: if true;
        allow write: if isParent(familyId);
      }

      match /chores/{choreId} {
        allow read: if true;
        allow write: if isParent(familyId);
      }

      match /pointRequests/{requestId} {
        allow create: if true;
        allow read, update, delete: if isParent(familyId);
      }

      match /activities/{activityId} {
        allow read: if true;
        allow write: if isParent(familyId);
      }

      match /cashouts/{cashoutId} {
        allow read: if true;
        allow write: if isParent(familyId);
      }
    }

    // Maps invited parents to their family
    match /parentFamilyMap/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Parent invite codes
    match /parentInvites/{inviteCode} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
